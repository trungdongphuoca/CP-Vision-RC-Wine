# Python
__pycache__/
*.py[cod]
*.pyo
.venv/
*.egg-info/

# ── Dữ liệu nội bộ / riêng tư ──────────────────────────────────────────────
# Toàn bộ thư mục Sapo (dữ liệu bán hàng nội bộ)
Sapo/
data/sapo/

# Dữ liệu X-Wines thô (lớn, tải lại từ Kaggle)
data/xwines/

# ── Luận văn / Báo cáo ─────────────────────────────────────────────────────
thesis/

# ── Thư mục lưu trữ (không cần track) ──────────────────────────────────────
old/

# ── Large data files ────────────────────────────────────────────────────────
data/raw/*.csv
data/processed/*.jsonl
data/cv_ground_truth/

# ── Model artifacts (large binary) ─────────────────────────────────────────
models/lora_wine_model/
models/*.zip
Archive.zip
*.safetensors
*.bin
*.pt
*.pth

# ── Vector store (rebuilt automatically) ───────────────────────────────────
chroma_db/

# ── Evaluation cache (regenerated) ─────────────────────────────────────────
results/*.npy
results/*.pkl
results/.matplotlib/
results/training_outputs/
results/*.csv
!results/baseline_comparison.csv
!results/final_comparison.csv
!results/evaluation_results_summary.csv
!results/cw_ease_eval_results.csv
!results/cornac_eval_results.csv

# ── Môi trường ─────────────────────────────────────────────────────────────
.env
.DS_Store

# ── Notebooks checkpoints ──────────────────────────────────────────────────
notebooks/.ipynb_checkpoints/

# ── Scratch / temp ─────────────────────────────────────────────────────────
scratch/

