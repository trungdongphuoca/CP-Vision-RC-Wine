   "source": [
    "# 🍷 Beam Search Evaluation — Fair Comparison\n",
    "Chạy Proposed Model với **Beam Search (k=10)** để so sánh công bằng với Baseline BM25/TF-IDF.\n",
    "\n",
    "**Mục tiêu:** Tính Recall@1, Recall@5, Recall@10, NDCG@10, MRR"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ─── CELL 1: Setup ───────────────────────────────────────────────\n",
    "import os\n",
    "os.chdir('/content/drive/MyDrive/CD3')\n",
    "\n",
    "!pip install -q unsloth xformers trl peft transformers accelerate bitsandbytes"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ─── CELL 2: Sync code từ local (nếu cần) ────────────────────────\n",
    "# Đảm bảo file constrained_eval.py mới nhất đã được upload lên Drive\n",
    "import subprocess\n",
    "result = subprocess.run(['head', '-5', 'evaluation/constrained_eval.py'], capture_output=True, text=True)\n",
    "print(result.stdout)\n",
    "print('✅ File OK' if 'Beam Search' in open('evaluation/constrained_eval.py').read() else '❌ Cần upload lại file mới')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ─── CELL 3: Kiểm tra GPU ────────────────────────────────────────\n",
    "import torch\n",
    "print(f'GPU: {torch.cuda.get_device_name(0)}')\n",
    "print(f'VRAM: {torch.cuda.get_device_properties(0).total_memory / 1e9:.1f} GB')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ─── CELL 4: Run Beam Search Evaluation ──────────────────────────\n",
    "# num_beams=10  → sinh ra 10 candidates cho mỗi query\n",
    "# batch_size=2  → an toàn với VRAM 15GB\n",
    "# eval_size=500 → 500 mẫu đầu tiên của test set (đúng với baseline)\n",
    "os.environ['PYTHONIOENCODING'] = 'utf-8'\n",
    "\n",
    "!python evaluation/constrained_eval.py \\\n",
    "    --eval_size 500 \\\n",
    "    --batch_size 2 \\\n",
    "    --num_beams 10 \\\n",
    "    --num_return_sequences 10 \\\n",
    "    --max_new_tokens 150 \\\n",
    "    --output results/constrained_eval_beam10_500.csv"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ─── CELL 5: Xem kết quả nhanh ───────────────────────────────────\n",
    "import pandas as pd\n",
    "df = pd.read_csv('results/constrained_eval_beam10_500.csv')\n",
    "\n",
    "print('=== PROPOSED MODEL — BEAM SEARCH (k=10) ===')\n",
    "print(f'Samples   : {len(df):,}')\n",
    "for k in [1, 5, 10]:\n",
    "    r = df[f'Recall@{k}'].mean() * 100\n",
    "    n = df[f'NDCG@{k}'].mean() * 100\n",
    "    c = df[f'ClusterMatch@{k}'].mean() * 100\n",
    "    print(f'Recall@{k}: {r:.2f}%  NDCG@{k}: {n:.2f}%  ClusterMatch@{k}: {c:.2f}%')\n",
    "print(f'MRR       : {df[\"MRR\"].mean()*100:.2f}%')\n",
    "print(f'Latency   : {df[\"latency_ms\"].mean():.0f} ms/query')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ─── CELL 6: Verify file đã được lưu ─────────────────────────────\n",
    "import os\n",
    "f = 'results/constrained_eval_beam10_500.csv'\n",
    "if os.path.exists(f):\n",
